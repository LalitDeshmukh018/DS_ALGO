// calulate the sum of max height at each step
// if we calulate the hright seperatly and compare it will the TC of n^2

class Solution {
    int ans  = 0 ;
    public int height (TreeNode root){
        
        if (root==null) return 0;
        int left = helper (root.left);
        int right = helper (root.right);
        ans = Math.max(ans, left+right);
        return 1 + helper (left, right);
    }
    public int diameterOfBinaryTree(TreeNode root) {
        height (root);
        return ans;
        
    }
}