// here
// why we make the another function -> if we pass sum as the globla varilabe each recursive call get the shared varible 
// if we pass it as the seperate as the local parameter then each call get its seperate value
// if we still want to pass the global varible then we need to backtrack the sum  ir to substract from the call


class Solution {
    public boolean helper (TreeNode root, int sum, int target ){
        if (root==null) return false;

        sum += root.val;

        if (root.left ==null && root.right==null && sum == target) return true;

        boolean left = helper (root.left, sum, target);
        boolean right = helper (root.right, sum, target);

        return left || right ;

    }
    public boolean hasPathSum(TreeNode root, int target) {
        boolean ans = helper (root, 0, target);
        return ans;
    
    }
}