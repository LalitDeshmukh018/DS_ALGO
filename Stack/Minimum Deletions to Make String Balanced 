class Solution {
    public int minimumDeletions(String s) {
        Stack<Character> st = new Stack<>();

        int del = 0 ;

        for (char ch : s.toCharArray()){
            if (!st.isEmpty() &&st.peek() == 'b' && ch == 'a'){
                st.pop();
                del ++;
            }
            else st.push(ch);
        }
        return del;
    }
}