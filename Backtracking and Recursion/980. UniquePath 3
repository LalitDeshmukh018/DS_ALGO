class Solution {

    public int helper (int i , int j , int grid[][], int obs, int count ,  boolean vis[][]){
        int n = grid.length;
        int m = grid[0].length;
        int ans = 0;

        if (i<0 || j<0 || i>=n || j>=m || vis[i][j] || grid[i][j] == -1) return 0 ;

        if (grid[i][j] ==2 && count == obs+1) ans ++;

        vis [i][j] = true;

        int dr [] = {-1,0,1,0};
        int dc [] = {0,1,0,-1};

        for (int k=0;k<4;k++){
            int nr = i + dr[k];
            int nc = j + dc[k];
            if (nr >=0 && nc >=0 && nr <n && nc <m && !vis[nr][nc] && grid[nr][nc] !=-1){

            ans += helper (nr, nc,grid ,obs, count +1,vis);}

        }
        vis [i][j] = false; 
        return ans;
    }
    public int uniquePathsIII(int[][] grid) {
        int n = grid.length;
        int m = grid[0].length;

        boolean vis [][] = new boolean [n][m];
        int start_x = 0;
        int start_y = 0 ;
        int obs = 0;

        for (int i=0;i<n;i++){
            for (int j=0;j<m;j++){

                if(grid [i][j] == 1){
                    start_x = i;
                    start_y = j;
                 }
                
                if (grid[i][j] ==0){
                    obs ++;
                }

            }
        }
        int ans = 0;
        ans = helper (start_x , start_y, grid, obs,0 , vis);
        return ans;

    }
}