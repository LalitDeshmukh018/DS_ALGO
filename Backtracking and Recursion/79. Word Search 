



class Solution {
    public boolean helper (int i, int j, char[][] board, String word ,int index, boolean vis[][]){
        
        int n = board.length;
        int m = board[0].length;

        if (index == word.length()) return true;
        if (i<0 || i >=n || j<0 || j>=m|| vis[i][j] || board[i][j] != word.charAt(index)) return false;
        vis [i][j] = true;

        if (helper (i,j+1,board, word, index+1, vis )|| 
            helper (i,j-1,board, word, index+1, vis ) ||
            helper (i+1,j,board, word, index+1, vis ) ||
            helper (i-1,j,board, word, index+1, vis ) ) return true;
    vis[i][j] = false;
    return false;

    }
    public boolean exist(char[][] board, String word) {
        int n = board.length;
        int m = board[0].length;
        boolean ans=  false;

        boolean vis[][] =  new boolean [n][m];


        for (int i=0;i<n;i++){
            for (int j=0;j<m;j++){
                if (board[i][j] == word.charAt(0)){
                   ans = helper (i,j,board, word,0,vis);
                   if (ans) return true;
                }
            }
        }
        return false;
    }

}